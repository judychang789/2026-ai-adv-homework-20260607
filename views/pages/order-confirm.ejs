<div id="app" data-order-id="<%= orderId %>">

  <!-- Step Progress Bar: 1 done, 2 done, 3 active (付款), 4 inactive -->
  <div class="flex items-start justify-center mb-8">
    <div class="flex flex-col items-center">
      <div class="w-8 h-8 rounded-full bg-success text-white flex items-center justify-center text-[13px] font-medium flex-shrink-0">✓</div>
      <span class="mt-1.5 text-[12px] font-medium text-success whitespace-nowrap">購物車</span>
    </div>
    <div class="h-px w-10 sm:w-6 bg-input-border mt-4 mx-2 flex-shrink-0"></div>
    <div class="flex flex-col items-center">
      <div class="w-8 h-8 rounded-full bg-success text-white flex items-center justify-center text-[13px] font-medium flex-shrink-0">✓</div>
      <span class="mt-1.5 text-[12px] font-medium text-success whitespace-nowrap">結帳資訊</span>
    </div>
    <div class="h-px w-10 sm:w-6 bg-input-border mt-4 mx-2 flex-shrink-0"></div>
    <div class="flex flex-col items-center">
      <div class="w-8 h-8 rounded-full bg-rose-primary text-white flex items-center justify-center text-[13px] font-medium flex-shrink-0">3</div>
      <span class="mt-1.5 text-[12px] font-medium text-rose-primary whitespace-nowrap">付款</span>
    </div>
    <div class="h-px w-10 sm:w-6 bg-input-border mt-4 mx-2 flex-shrink-0"></div>
    <div class="flex flex-col items-center">
      <div class="w-8 h-8 rounded-full bg-footer-link text-white flex items-center justify-center text-[13px] font-medium flex-shrink-0">4</div>
      <span class="mt-1.5 text-[12px] font-medium text-footer-link whitespace-nowrap">完成</span>
    </div>
  </div>

  <!-- Loading -->
  <div v-if="loading" class="flex justify-center py-12">
    <div class="w-8 h-8 border-4 border-rose-primary border-t-transparent rounded-full animate-spin"></div>
  </div>

  <template v-else-if="order">
    <div class="flex flex-col lg:flex-row gap-6 lg:items-start">

      <!-- ── Left: Order Details ── -->
      <div class="w-full lg:w-[65%]">
        <div class="bg-white rounded-2xl shadow-sm p-6">

          <!-- Header: title + order number tag -->
          <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
            <h1 class="text-brand-dark text-[24px] font-bold">確認訂單明細</h1>
            <span class="bg-order-tag-bg text-order-tag text-[13px] font-semibold py-[6px] px-[14px] rounded-full whitespace-nowrap">
              訂單編號：{{ order.order_no }}
            </span>
          </div>

          <!-- Order items -->
          <div class="space-y-4 mb-5">
            <div v-for="item in order.items" :key="item.product_id || item.product_name"
                 class="flex items-center gap-3">
              <!-- Product image -->
              <img :src="item.product_image || '/images/products/cat-food_001.png'"
                   :alt="item.product_name"
                   @error="$event.target.src = '/images/products/cat-food_001.png'"
                   class="w-12 h-12 rounded-xl object-cover flex-shrink-0" />
              <!-- Info -->
              <div class="flex-1 min-w-0">
                <p class="text-brand-dark font-bold text-[14px] truncate">{{ item.product_name }}</p>
                <p class="text-footer-link text-[12px]">數量：{{ item.quantity }}</p>
              </div>
              <!-- Price -->
              <span class="font-price font-bold text-rose-primary text-[16px] flex-shrink-0">
                NT${{ (item.product_price * item.quantity).toLocaleString() }}
              </span>
            </div>
          </div>

          <div class="border-t border-footer-link/20 mb-5"></div>

          <!-- 配送地址 | 付款方式 -->
          <div class="grid grid-cols-1 lg:grid-cols-2">

            <!-- 配送地址 -->
            <div class="pb-5 lg:pb-0 lg:pr-6 border-b lg:border-b-0 border-footer-link/20">
              <div class="flex items-center gap-2 mb-3">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-rose-primary flex-shrink-0">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                </svg>
                <span class="text-brand-dark font-bold text-[14px]">配送地址</span>
              </div>
              <p class="text-brand-dark text-[14px] font-medium mb-1">{{ order.recipient_name }}</p>
              <p class="text-nav-link text-[13px] mb-1">{{ order.recipient_address }}</p>
              <p class="text-footer-link text-[12px]">預計 {{ estimatedDelivery }} 到達</p>
            </div>

            <!-- 付款方式 -->
            <div class="pt-5 lg:pt-0 lg:pl-6 lg:border-l lg:border-footer-link/20">
              <div class="flex items-center gap-2 mb-3">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-rose-primary flex-shrink-0">
                  <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>
                </svg>
                <span class="text-brand-dark font-bold text-[14px]">付款方式</span>
              </div>
              <p class="text-nav-link text-[13px] mb-0.5">{{ paymentLabel }}</p>
              <p class="text-nav-link text-[13px] mb-0.5">Visa 金融卡</p>
              <p class="text-nav-link text-[13px]">NT${{ order.total_amount.toLocaleString() }} 確認後付款</p>
            </div>

          </div>

        </div>
      </div>

      <!-- ── Right: 費用總計 ── -->
      <div class="w-full lg:w-[35%]">
        <div class="bg-white rounded-2xl shadow-sm overflow-hidden lg:sticky lg:top-24">

          <!-- Pink header -->
          <div class="bg-rose-primary px-5 py-3.5">
            <h2 class="text-white font-bold text-[18px]">費用總計</h2>
          </div>

          <div class="p-5">

            <!-- 費用明細 -->
            <div class="space-y-2.5 mb-4 text-[14px]">
              <div class="flex justify-between">
                <span class="text-nav-link">商品小計</span>
                <span class="text-brand-dark font-medium">NT${{ subtotal.toLocaleString() }}</span>
              </div>
              <div class="flex justify-between">
                <span class="text-nav-link">運費</span>
                <span v-if="shipping === 0" class="text-nav-link font-medium">免運</span>
                <span v-else class="text-brand-dark font-medium">NT${{ shipping.toLocaleString() }}</span>
              </div>
              <div v-if="discount > 0" class="flex justify-between">
                <span class="text-nav-link">折扣優惠</span>
                <span class="text-rose-primary font-medium">-NT${{ discount.toLocaleString() }}</span>
              </div>
            </div>

            <div class="border-t border-footer-link/20 mb-4"></div>

            <!-- 應付金額 -->
            <div class="flex justify-between items-center mb-5">
              <span class="font-bold text-brand-dark text-[16px]">應付金額</span>
              <span class="font-price font-bold text-rose-primary text-[24px] leading-none">NT${{ order.total_amount.toLocaleString() }}</span>
            </div>

            <!-- 確認付款 button -->
            <button @click="startEcpayCheckout"
                    :disabled="paying"
                    class="w-full bg-rose-primary text-white py-3 rounded-full text-[15px] font-medium hover:bg-rose-dark transition-colors disabled:opacity-50 flex items-center justify-center gap-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>
              </svg>
              {{ paying ? '導向綠界中...' : '確認付款 NT$' + order.total_amount.toLocaleString() }}
            </button>

            <!-- 返回修改 -->
            <div class="text-center mt-3">
              <a href="/checkout" class="text-footer-link text-[13px] hover:text-nav-link transition-colors">← 返回修改</a>
            </div>

            <p class="text-center text-footer-link text-[11px] mt-2.5">🔒 確認後完成支付，保障安全交易</p>

          </div>
        </div>
      </div>

    </div>
  </template>

</div>
