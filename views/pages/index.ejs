<div id="app">

  <!-- Hero Banner -->
  <section class="mb-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 items-center py-10 lg:py-16 gap-8 lg:gap-12">

      <!-- Left: text — 1/3 on desktop, bottom on mobile -->
      <div class="flex flex-col items-center lg:items-start text-center lg:text-left order-last lg:order-first">

        <!-- Tag -->
        <div class="inline-flex items-center gap-1.5 bg-tag-bg text-nav-link text-[12px] font-medium py-1.5 px-3.5 rounded-full mb-5">
          <img src="/images/logo.webp" alt="" class="w-3 h-3 object-contain opacity-60">
          日本・台灣嚴選
        </div>

        <!-- Main title -->
        <h1 class="font-serif-tc font-bold text-footer-bottom text-[32px] lg:text-[54px] leading-tight mb-5">
          讓毛孩的每一天<br>都是美好日和
        </h1>

        <!-- Subtitle -->
        <p class="text-nav-link text-[15px] leading-relaxed mb-8">
          嚴選天然有機食材，獸醫師推薦配方<br>給毛孩最純淨的日常呵護
        </p>

        <!-- Buttons -->
        <div class="flex flex-wrap gap-3 justify-center lg:justify-start">
          <a href="#products" class="bg-footer-bottom text-white text-[14px] font-medium rounded-full px-8 py-3 hover:opacity-80 transition-opacity">
            探索商品 →
          </a>
          <a href="#about" class="bg-white border border-footer-link text-nav-link text-[14px] font-medium rounded-full px-8 py-3 hover:opacity-80 transition-opacity">
            品牌故事
          </a>
        </div>

      </div>

      <!-- Right: image — 2/3 on desktop, top on mobile -->
      <div class="lg:col-span-2 flex justify-center lg:justify-end w-full order-first lg:order-last">
        <div class="overflow-hidden shadow-xl w-full aspect-[839/440] rounded-[990px]">
          <img src="/images/home/banner.webp" alt="可愛毛孩" class="w-full h-full object-cover">
        </div>
      </div>

    </div>
  </section>

  <!-- Category Section -->
  <section class="mb-12">
    <div class="text-center mb-8">
      <h2 class="font-serif-tc font-bold text-brand-dark text-[32px]">探索寵物世界</h2>
      <p class="text-nav-link text-[15px] mt-2">為您的毛孩找到最適合的商品</p>
    </div>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="bg-card-dog rounded-2xl p-6 pb-10 text-center cursor-pointer hover:shadow-md transition-all hover:-translate-y-1 relative group">
        <img src="/images/category_icon_01.webp" alt="狗狗商品" class="w-[51px] h-[51px] mx-auto mb-3 object-contain">
        <h3 class="font-bold text-brand-dark text-[18px]">狗狗商品</h3>
        <p class="text-nav-link text-[14px] mt-1">狗糧・玩具・零食</p>
        <span class="absolute bottom-4 right-4 text-text-muted text-sm group-hover:text-rose-primary transition-colors">→</span>
      </div>
      <div class="bg-card-cat rounded-2xl p-6 pb-10 text-center cursor-pointer hover:shadow-md transition-all hover:-translate-y-1 relative group">
        <img src="/images/category_icon_02.webp" alt="貓咪商品" class="w-[51px] h-[51px] mx-auto mb-3 object-contain">
        <h3 class="font-bold text-brand-dark text-[18px]">貓咪商品</h3>
        <p class="text-nav-link text-[14px] mt-1">貓糧・玩具・零食</p>
        <span class="absolute bottom-4 right-4 text-text-muted text-sm group-hover:text-rose-primary transition-colors">→</span>
      </div>
      <div class="bg-card-bird rounded-2xl p-6 pb-10 text-center cursor-pointer hover:shadow-md transition-all hover:-translate-y-1 relative group">
        <img src="/images/category_icon_03.webp" alt="鳥禽商品" class="w-[51px] h-[51px] mx-auto mb-3 object-contain">
        <h3 class="font-bold text-brand-dark text-[18px]">鳥禽商品</h3>
        <p class="text-nav-link text-[14px] mt-1">飼料・籠具・玩具</p>
        <span class="absolute bottom-4 right-4 text-text-muted text-sm group-hover:text-rose-primary transition-colors">→</span>
      </div>
      <div class="bg-card-small rounded-2xl p-6 pb-10 text-center cursor-pointer hover:shadow-md transition-all hover:-translate-y-1 relative group">
        <img src="/images/category_icon_04.webp" alt="小動物" class="w-[51px] h-[51px] mx-auto mb-3 object-contain">
        <h3 class="font-bold text-brand-dark text-[18px]">小動物</h3>
        <p class="text-nav-link text-[14px] mt-1">倉鼠・兔子・鼠鼠</p>
        <span class="absolute bottom-4 right-4 text-text-muted text-sm group-hover:text-rose-primary transition-colors">→</span>
      </div>
    </div>
  </section>

  <!-- Hot Products -->
  <section id="products" class="mb-12">
    <div class="flex items-end justify-between mb-6">
      <div>
        <h2 class="font-serif-tc font-bold text-brand-dark text-[32px]">熱銷商品</h2>
        <p class="text-nav-link text-[15px] mt-1">毛孩的最愛，主人的首選</p>
      </div>
      <a href="/" class="text-rose-primary text-sm hover:underline font-medium">查看更多 →</a>
    </div>

    <div v-if="loading" class="flex justify-center py-12">
      <div class="w-8 h-8 border-4 border-rose-primary border-t-transparent rounded-full animate-spin"></div>
    </div>

    <template v-else>
      <div v-if="products.length === 0" class="text-center py-12">
        <div class="text-4xl mb-3">🐾</div>
        <p class="text-text-secondary">目前沒有商品</p>
        <p class="text-text-muted text-sm">請稍後再來看看</p>
      </div>

      <div v-else class="grid grid-cols-2 lg:grid-cols-4 gap-5">
        <div
          v-for="(product, idx) in products.slice(0, 4)"
          :key="product.id"
          @click="goToProduct(product.id)"
          class="bg-white rounded-2xl shadow-sm overflow-hidden cursor-pointer hover:shadow-md transition-all hover:-translate-y-1 group relative"
        >
          <div class="absolute top-3 left-3 z-10">
            <span class="bg-rose-primary text-white text-xs px-2.5 py-0.5 rounded-full font-medium">New</span>
          </div>
          <div class="aspect-[305/200] overflow-hidden bg-product-bg">
            <img
              :src="product.image_url || featuredImages[idx % 4]"
              :alt="product.name"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            />
          </div>
          <div class="p-4">
            <!-- Star rating -->
            <div class="flex items-center gap-1 mb-1.5">
              <template v-for="i in 5" :key="i">
                <svg v-if="i <= Math.round(product.rating || 4)" width="16" height="16" viewBox="0 0 24 24" class="text-apricot flex-shrink-0">
                  <path fill="currentColor" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
                <svg v-else width="16" height="16" viewBox="0 0 24 24" class="text-footer-link flex-shrink-0">
                  <path fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              </template>
              <span class="font-meta text-footer-link text-[11px] ml-0.5">({{ product.review_count }})</span>
            </div>
            <h3 class="text-brand-dark text-[14px] font-medium mb-2 truncate">{{ product.name }}</h3>
            <div class="flex items-center justify-between">
              <div>
                <div class="font-price text-rose-primary font-bold text-[18px] leading-none mb-0.5">NT$ {{ product.price.toLocaleString() }}</div>
                <div v-if="product.original_price" class="font-meta text-footer-link text-[12px] line-through">NT$ {{ product.original_price.toLocaleString() }}</div>
              </div>
              <button
                @click.stop="addToCart(product)"
                :disabled="product._adding || product.stock <= 0"
                class="w-9 h-9 bg-rose-primary text-white rounded-full flex items-center justify-center text-xl hover:bg-rose-dark transition-colors disabled:opacity-50 disabled:cursor-not-allowed flex-shrink-0"
                :title="product.stock <= 0 ? '已售完' : '加入購物車'"
              >+</button>
            </div>
          </div>
        </div>
      </div>

      <div v-if="pagination.totalPages > 1" class="flex justify-center gap-2 mt-8">
        <button
          v-for="p in pagination.totalPages"
          :key="p"
          @click="loadProducts(p)"
          class="w-10 h-10 rounded-full text-sm transition-colors"
          :class="p === pagination.page ? 'bg-rose-primary text-white' : 'bg-white text-text-secondary hover:bg-rose-bg'"
        >
          {{ p }}
        </button>
      </div>
    </template>
  </section>

</div>
