<style>
  @keyframes pop-in {
    0%   { transform: scale(0.4); opacity: 0; }
    70%  { transform: scale(1.12); opacity: 1; }
    100% { transform: scale(1); }
  }
  @keyframes draw-check {
    from { stroke-dashoffset: 80; }
    to   { stroke-dashoffset: 0; }
  }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .anim-pop  { animation: pop-in 0.55s cubic-bezier(.26,1.4,.56,1) both; }
  .anim-check { stroke-dasharray: 80; animation: draw-check 0.45s 0.45s ease-out both; }
  .anim-fade { animation: fade-up 0.5s ease-out both; }
  .anim-delay-1 { animation-delay: 0.55s; }
  .anim-delay-2 { animation-delay: 0.7s; }
  .anim-delay-3 { animation-delay: 0.85s; }
</style>

<div id="app" data-order-id="<%= orderId %>">

  <!-- ── Step Progress Bar — all complete ── -->
  <div class="flex items-start justify-center mb-8">
    <% [['購物車',1],['結帳資訊',2],['付款',3],['完成',4]].forEach(function(s, i) { %>
    <div class="flex flex-col items-center">
      <div class="w-8 h-8 rounded-full bg-success text-white flex items-center justify-center text-[13px] font-medium flex-shrink-0">✓</div>
      <span class="mt-1.5 text-[12px] font-medium text-success whitespace-nowrap"><%= s[0] %></span>
    </div>
    <% if (i < 3) { %><div class="h-px w-10 sm:w-6 bg-success/40 mt-4 mx-2 flex-shrink-0"></div><% } %>
    <% }); %>
  </div>

  <!-- ── Success Hero ── -->
  <div class="flex flex-col items-center mb-8 anim-fade">
    <!-- Animated checkmark circle -->
    <div class="relative mb-5 anim-pop">
      <div class="w-24 h-24 rounded-full flex items-center justify-center"
           style="background: radial-gradient(circle at 35% 35%, #7fe08a, #4caf56);">
        <!-- Halo rings -->
        <div class="absolute inset-0 rounded-full border-4 border-success/20 scale-110"></div>
        <div class="absolute inset-0 rounded-full border-2 border-success/10 scale-125"></div>
        <svg width="44" height="44" viewBox="0 0 44 44" fill="none">
          <polyline class="anim-check" points="8,23 18,33 36,13"
                    stroke="white" stroke-width="4.5"
                    stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
    <h1 class="font-serif-tc font-bold text-[28px] sm:text-[22px] text-brand-dark anim-fade anim-delay-1">
      付款成功！感謝您的購買 🎉
    </h1>
    <p class="text-nav-link text-[14px] mt-1.5 anim-fade anim-delay-2">
      我們已收到您的付款，將盡快為您出貨 🐾
    </p>
  </div>

  <!-- ── Loading ── -->
  <div v-if="loading" class="flex justify-center py-12">
    <div class="w-8 h-8 border-4 border-rose-primary border-t-transparent rounded-full animate-spin"></div>
  </div>

  <template v-else-if="order">
    <div class="flex flex-col lg:flex-row gap-6 lg:items-start anim-fade anim-delay-3">

      <!-- ── Left: Order Card ── -->
      <div class="w-full lg:w-[63%]">
        <div class="bg-white rounded-2xl shadow-sm p-6">

          <!-- Order number header -->
          <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
            <h2 class="text-brand-dark text-[18px] font-bold">訂單明細</h2>
            <span class="bg-order-tag-bg text-order-tag text-[13px] font-semibold py-[6px] px-[14px] rounded-full whitespace-nowrap">
              訂單編號：{{ order.order_no }}
            </span>
          </div>

          <!-- Items -->
          <div class="space-y-3 mb-5">
            <div v-for="item in order.items" :key="item.product_id || item.product_name"
                 class="flex items-center gap-3">
              <img :src="item.product_image || '/images/products/cat-food_001.png'"
                   :alt="item.product_name"
                   @error="$event.target.src='/images/products/cat-food_001.png'"
                   class="w-12 h-12 rounded-xl object-cover flex-shrink-0">
              <div class="flex-1 min-w-0">
                <p class="text-brand-dark font-bold text-[14px] truncate">{{ item.product_name }}</p>
                <p class="text-footer-link text-[12px]">數量：{{ item.quantity }}</p>
              </div>
              <span class="font-price font-bold text-rose-primary text-[16px] flex-shrink-0">
                NT${{ (item.product_price * item.quantity).toLocaleString() }}
              </span>
            </div>
          </div>

          <div class="border-t border-footer-link/20 mb-4"></div>

          <!-- Total -->
          <div class="flex items-center justify-between">
            <span class="text-nav-link text-[14px]">應付總金額</span>
            <span class="font-price font-bold text-rose-primary text-[24px] leading-none">
              NT${{ order.total_amount.toLocaleString() }}
            </span>
          </div>

          <div class="border-t border-footer-link/20 my-4"></div>

          <!-- Recipient -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-[13px]">
            <div>
              <p class="text-footer-link mb-1">收件人</p>
              <p class="text-brand-dark font-medium">{{ order.recipient_name }}</p>
            </div>
            <div>
              <p class="text-footer-link mb-1">配送地址</p>
              <p class="text-brand-dark font-medium">{{ order.recipient_address }}</p>
            </div>
          </div>

        </div>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-3 mt-5">
          <a href="/products"
             class="flex-1 bg-rose-primary text-white text-center py-3 rounded-full text-[15px] font-medium hover:bg-rose-dark transition-colors">
            繼續購物
          </a>
          <a :href="'/orders/' + order.id"
             class="flex-1 border border-rose-primary text-rose-primary text-center py-3 rounded-full text-[15px] font-medium hover:bg-blush transition-colors">
            查看訂單記錄
          </a>
        </div>
      </div>

      <!-- ── Right: Side Info ── -->
      <div class="w-full lg:w-[37%] flex flex-col gap-4">

        <!-- Pet knowledge card -->
        <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
          <div class="bg-rose-primary px-5 py-3.5">
            <h3 class="text-white font-bold text-[16px]">喜歡寵物知識！</h3>
          </div>
          <div class="p-5 text-[13px] text-nav-link leading-relaxed space-y-2">
            <p>🐱 貓咪每天需要 12–16 小時的睡眠，是自然界睡眠時間最長的動物之一。</p>
            <p>🐶 狗狗的嗅覺比人類靈敏 10,000 倍，能夠偵測到細微的氣味變化。</p>
            <div class="mt-3">
              <div class="text-[11px] text-footer-link mb-1">距下次免費配送</div>
              <div class="w-full bg-rose-bg rounded-full h-2">
                <div class="bg-rose-primary h-2 rounded-full" style="width: 72%"></div>
              </div>
              <p class="text-[11px] text-footer-link mt-1">再購 NT$139 即可享免運！</p>
            </div>
          </div>
        </div>

        <!-- Share card -->
        <div class="bg-white rounded-2xl shadow-sm p-5">
          <h3 class="text-brand-dark font-bold text-[15px] mb-3">分享愛寵樂趣 🐾</h3>
          <p class="text-nav-link text-[13px] mb-4 leading-relaxed">
            把您的毛孩日常分享給更多朋友，讓更多人加入暮寵日和的大家庭！
          </p>
          <div class="flex gap-2">
            <button class="flex-1 flex items-center justify-center gap-1.5 py-2.5 rounded-xl text-[13px] font-medium transition-colors"
                    style="background:#06C755; color:white;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 4.944 0 11.04c0 3.49 1.742 6.6 4.47 8.625V24l4.078-2.246C9.534 22.11 10.74 22.24 12 22.24c6.627 0 12-4.944 12-11.04S18.627 0 12 0z"/></svg>
              LINE
            </button>
            <button class="flex-1 flex items-center justify-center gap-1.5 py-2.5 rounded-xl text-[13px] font-medium transition-colors"
                    style="background:#1877f2; color:white;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073C24 5.404 18.627 0 12 0S0 5.404 0 12.073c0 6.023 4.385 11.017 10.125 11.927v-8.437H7.078v-3.49h3.047V9.428c0-3.026 1.792-4.697 4.533-4.697 1.312 0 2.686.235 2.686.235v2.97h-1.514c-1.491 0-1.956.93-1.956 1.874v2.263h3.328l-.532 3.49h-2.796V24C19.615 23.09 24 18.096 24 12.073z"/></svg>
              Facebook
            </button>
            <button @click="copyLink"
                    class="flex-1 flex items-center justify-center gap-1.5 py-2.5 rounded-xl text-[13px] font-medium border border-input-border text-nav-link hover:bg-blush transition-colors">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              複製
            </button>
          </div>
        </div>

      </div>
    </div>
  </template>

  <!-- Error state -->
  <div v-else-if="!loading" class="text-center py-16">
    <p class="text-nav-link text-[15px]">找不到訂單資料</p>
    <a href="/orders" class="mt-4 inline-block text-rose-primary text-[14px] hover:underline">查看我的訂單</a>
  </div>

</div>

<script>
(function () {
  const { createApp, ref, onMounted } = Vue;

  createApp({
    setup() {
      const el = document.getElementById('app');
      const orderId = el.dataset.orderId;
      const order = ref(null);
      const loading = ref(true);

      onMounted(async function () {
        try {
          const token = localStorage.getItem('flower_token');
          const res = await fetch('/api/orders/' + orderId, {
            headers: token ? { Authorization: 'Bearer ' + token } : {}
          });
          if (res.ok) {
            const json = await res.json();
            order.value = json.data;
          }
        } catch (e) {
          console.error(e);
        } finally {
          loading.value = false;
        }
      });

      function copyLink() {
        navigator.clipboard.writeText(window.location.origin + '/products')
          .then(function () { alert('已複製連結！'); })
          .catch(function () {});
      }

      return { order, loading, copyLink };
    }
  }).mount('#app');
})();
</script>
